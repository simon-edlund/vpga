# Copy this to .env and fill in your values before running docker compose
JWT_SECRET=change-this-to-a-long-random-string
# MinGolf credentials for automatic HCP updates
MINGOLF_USERNAME=your-mingolf-golf-id
MINGOLF_PASSWORD=your-mingolf-password
# Cron schedule for HCP updates (default: every Friday at 08:00)
# HCP_UPDATE_CRON=0 8 * * 5
